<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta charset="UTF-8">
<meta name="ProgId" content="Word.Document">
<meta name="Generator" content="Microsoft Word compatible HTML">
<title>一题三变_库仑定律_规范解析</title>
<style>
@page { size: A4; margin: 2.2cm 2.1cm; }
body { font-family: SimSun, 宋体, serif; font-size: 12pt; line-height: 1.65; color: #111; }
h1 { text-align: center; font-family: SimHei, 黑体, sans-serif; font-size: 18pt; margin: 0 0 8pt 0; }
h2 { text-align: center; font-family: SimHei, 黑体, sans-serif; font-size: 15pt; margin: 0 0 18pt 0; }
h3 { font-family: SimHei, 黑体, sans-serif; font-size: 14pt; margin: 18pt 0 8pt 0; }
p { margin: 0 0 7pt 0; text-align: justify; }
.label { font-family: SimHei, 黑体, sans-serif; font-weight: bold; margin-top: 10pt; }
.formula { text-align: center; font-family: 'Times New Roman', serif; font-size: 12pt; margin: 7pt 0; }
.var { font-family: 'Times New Roman', serif; font-style: italic; }
.unit { font-family: 'Times New Roman', serif; font-style: normal; }
.frac { display: inline-block; vertical-align: middle; text-align: center; line-height: 1.1; margin: 0 2px; }
.frac .top { display: block; border-bottom: 1px solid #000; padding: 0 3px 2px 3px; }
.frac .bottom { display: block; padding: 2px 3px 0 3px; }
.meta { margin: 2pt 0; }
.pagebreak { page-break-before: always; }
</style>
